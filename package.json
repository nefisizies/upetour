{
  "name": "turplatform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start:prod": "prisma migrate deploy && next start",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "seed": "npx tsx prisma/seed.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:api": "npx tsx tests/api-check.ts",
    "test:visual": "TEST_URL=http://localhost:3000 npx playwright test tests/e2e/visual-feedback.spec.ts --reporter=list",
    "test:visual:prod": "npx playwright test tests/e2e/visual-feedback.spec.ts --reporter=list"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^5.22.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-auth": "^4.24.14",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-colorful": "^5.6.1",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "playwright": "^1.59.1",
    "typescript": "^5"
  }
}
