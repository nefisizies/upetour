generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  password         String
  role             Role
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  acenteProfile    AcenteProfile?
  bildirimler      Bildirim[]
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  rehberProfile    RehberProfile?
  receivedReviews  Review[]       @relation("ReceivedReviews")
  givenReviews     Review[]       @relation("GivenReviews")
}

model RehberProfile {
  id                 String                  @id @default(cuid())
  userId             String                  @unique
  slug               String                  @unique
  name               String
  bio                String?
  city               String?
  photoUrl           String?
  specialties        String[]
  experienceYears    Int                     @default(0)
  isAvailable        Boolean                 @default(true)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  operatingCountries String[]                @default([])
  bloklar            AcenteRehberBlok[]
  referanslar        Referans[]
  languages          RehberDil[]
  licenses           RehberLicense[]
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  takvimEtkinlikleri TakvimEtkinlik[]
  tours              Tour[]
  acenteEtkinlikleri AcenteTakvimEtkinlik[]
}

model RehberDil {
  id        String        @id @default(cuid())
  rehberId  String
  dil       String
  seviye    String?
  sertifika String?
  sonuc     String?
  createdAt DateTime      @default(now())
  rehber    RehberProfile @relation(fields: [rehberId], references: [id], onDelete: Cascade)

  @@unique([rehberId, dil])
}

model RehberLicense {
  id          String        @id @default(cuid())
  rehberId    String
  country     String
  licenseType String
  licenseNo   String
  status      LicenseStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  rehber      RehberProfile @relation(fields: [rehberId], references: [id], onDelete: Cascade)
}

model AcenteProfile {
  id          String                  @id @default(cuid())
  userId      String                  @unique
  slug        String                  @unique
  companyName String
  description String?
  city        String?
  logoUrl     String?
  website     String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  bloklar     AcenteRehberBlok[]
  referanslar Referans[]
  etkinlikler AcenteTakvimEtkinlik[]
}

model AcenteRehberBlok {
  id        String        @id @default(cuid())
  acenteId  String
  rehberId  String
  tur       BlokTur
  banBitis  DateTime?
  createdAt DateTime      @default(now())
  acente    AcenteProfile @relation(fields: [acenteId], references: [id], onDelete: Cascade)
  rehber    RehberProfile @relation(fields: [rehberId], references: [id], onDelete: Cascade)

  @@unique([acenteId, rehberId])
}

model Referans {
  id        String        @id @default(cuid())
  rehberId  String
  acenteId  String
  durum     ReferansDurum @default(BEKLIYOR)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  acente    AcenteProfile @relation(fields: [acenteId], references: [id], onDelete: Cascade)
  rehber    RehberProfile @relation(fields: [rehberId], references: [id], onDelete: Cascade)

  @@unique([rehberId, acenteId])
}

model Tour {
  id          String        @id @default(cuid())
  rehberId    String
  title       String
  description String?
  duration    String?
  location    String?
  priceRange  String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  rehber      RehberProfile @relation(fields: [rehberId], references: [id], onDelete: Cascade)
}

model Bildirim {
  id        String      @id @default(cuid())
  userId    String
  tip       BildirimTip
  baslik    String
  metin     String?
  link      String?
  okundu    Boolean     @default(false)
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TakvimEtkinlik {
  id        String        @id @default(cuid())
  rehberId  String
  baslik    String
  baslangic DateTime
  bitis     DateTime?
  notlar    String?
  tur       EtkinlikTur   @default(MANUEL)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  rehber    RehberProfile @relation(fields: [rehberId], references: [id], onDelete: Cascade)
}

model AcenteTakvimEtkinlik {
  id        String        @id @default(cuid())
  acenteId  String
  baslik    String
  baslangic DateTime
  bitis     DateTime?
  lokasyon  String?
  rehberId  String?
  notlar    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  acente    AcenteProfile @relation(fields: [acenteId], references: [id], onDelete: Cascade)
  rehber    RehberProfile? @relation(fields: [rehberId], references: [id], onDelete: SetNull)
}

model Message {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  from       User     @relation("SentMessages", fields: [fromUserId], references: [id])
  to         User     @relation("ReceivedMessages", fields: [toUserId], references: [id])
}

model Review {
  id         String   @id @default(cuid())
  reviewerId String
  revieweeId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  reviewee   User     @relation("ReceivedReviews", fields: [revieweeId], references: [id])
  reviewer   User     @relation("GivenReviews", fields: [reviewerId], references: [id])
}

enum Role {
  REHBER
  ACENTE
  ADMIN
}

enum LicenseStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ReferansDurum {
  BEKLIYOR
  ONAYLANDI
  REDDEDILDI
  KALDIRILDI
}

enum EtkinlikTur {
  MANUEL
  REZERVASYON
}

enum BlokTur {
  GECICI
  KALICI
}

enum BildirimTip {
  MESAJ
  REFERANS
  SISTEM
}
